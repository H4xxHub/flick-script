-- ================== MAIN LOOP ==================
RunService.RenderStepped:Connect(function()
    if not authenticated then return end
    
    -- UPDATE FOV CIRCLE
    if settings.Aimbot.ShowFOV then
        fovCircle.Radius = (settings.Aimbot.FOV / 2) * (camera.ViewportSize.Y / 100)
        fovCircle.Position = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
        fovCircle.Visible = true
        
        if settings.Aimbot.FOVRainbow then
            local hue = (tick() * rainbowSpeed) % 1
            fovCircle.Color = Color3.fromHSV(hue, 1, 1)
        else
            fovCircle.Color = settings.Aimbot.FOVColor
        end
    else
        fovCircle.Visible = false
    end
    
    -- UPDATE ESP
    for plr, drawings in pairs(espDrawings) do
        updateESP(plr, drawings)
    end
    
    -- AIMLOCK
    if settings.Aimbot.Enabled then
        local targets = findTargetsInFOV()
        
        if #targets > 0 then
            local target = targets[1].player
            local head = targets[1].head
            
            if target and target.Character and head then
                camera.CFrame = CFrame.lookAt(camera.CFrame.Position, head.Position)
            end
        end
    end
end)

