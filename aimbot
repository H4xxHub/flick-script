enterBtn.MouseButton1Click:Connect(function()
    local inputKey = keyInput.Text
    if VALID_KEYS[inputKey] then
        -- Key benar
        notif.Text = "KEY BENAR! LOADING..."
        notif.TextColor3 = Color3.fromRGB(150, 150, 150)
        
        -- Hide key GUI
        keyGui.Enabled = false
        
        -- Show loading GUI
        loadingGui.Enabled = true
        
        -- Animasi spinner
        local angle = 0
        local spinConnection
        spinConnection = RunService.RenderStepped:Connect(function()
            angle = angle + 0.05
            for i, dot in ipairs(dots) do
                local rad = angle + (i * math.pi / 4)
                local x = 35 + math.cos(rad) * 30
                local y = 35 + math.sin(rad) * 30
                dot.Position = UDim2.new(0, x, 0, y)
                
                local alpha = 0.5 + (math.sin(rad * 3) * 0.5)
                dot.BackgroundTransparency = 1 - alpha
            end
        end)
        
        -- Progress bar animation
        local progress = 0
        local msgIndex = 1
        local loadTime = 5
        
        for i = 1, 50 do
            task.wait(loadTime / 50)
            progress = progress + 0.02
            progressFill.Size = UDim2.new(progress, 0, 1, 0)
            
            if i % 8 == 0 and msgIndex <= #loadingMessages then
                loadingText.Text = loadingMessages[msgIndex]
                msgIndex = msgIndex + 1
            end
        end
        
        spinConnection:Disconnect()
        loadingGui.Enabled = false
        mainPanelGui.Enabled = true
        
    else
        -- Key salah
        notif.Text = "KEY SALAH! COBA LAGI"
        notif.TextColor3 = Color3.fromRGB(200, 100, 100)
        keyInput.Text = ""
        TweenService:Create(keyInput, TweenInfo.new(0.1), {Position = UDim2.new(0.1, 10, 0, 170)}):Play()
        task.wait(0.1)
        TweenService:Create(keyInput, TweenInfo.new(0.1), {Position = UDim2.new(0.1, -10, 0, 170)}):Play()
        task.wait(0.1)
        TweenService:Create(keyInput, TweenInfo.new(0.1), {Position = UDim2.new(0.1, 0, 0, 170)}):Play()
    end
end)

