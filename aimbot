-- ================== FUNGSI CREATE ESP ==================
local function createESP(plr)
    if plr == player then return end
    
    local drawings = {
        Box = Drawing.new("Square"),
        Distance = Drawing.new("Text"),
        Snapline = Drawing.new("Line")
    }
    
    drawings.Box.Thickness = settings.ESP.BoxThickness
    drawings.Box.Filled = false
    drawings.Box.Color = settings.ESP.BoxColor
    drawings.Box.Visible = false
    
    drawings.Distance.Size = 14
    drawings.Distance.Center = true
    drawings.Distance.Color = settings.ESP.DistanceColor
    drawings.Distance.Visible = false
    
    drawings.Snapline.Thickness = 1.5
    drawings.Snapline.Color = settings.ESP.BoxColor
    drawings.Snapline.Visible = false
    
    espDrawings[plr] = drawings
end

-- ================== FUNGSI UPDATE ESP ==================
local function updateESP(plr, drawings)
    if not settings.ESP.Enabled or not plr.Character then
        for _, d in pairs(drawings) do d.Visible = false end
        return
    end
    
    local humanoid = plr.Character:FindFirstChildOfClass("Humanoid")
    local head = plr.Character:FindFirstChild("Head")
    local root = plr.Character:FindFirstChild("HumanoidRootPart")
    
    if not humanoid or humanoid.Health <= 0 or not head or not root then
        for _, d in pairs(drawings) do d.Visible = false end
        return
    end
    
    local headPos, onScreen = camera:WorldToViewportPoint(head.Position)
    local rootPos = camera:WorldToViewportPoint(root.Position)
    
    if not onScreen then
        for _, d in pairs(drawings) do d.Visible = false end
        return
    end
    
    local distance = (head.Position - camera.CFrame.Position).Magnitude
    local scale = 1000 / distance
    local boxHeight = scale * 2.2
    local boxWidth = scale * 1.6
    
    drawings.Box.Size = Vector2.new(boxWidth, boxHeight)
    drawings.Box.Position = Vector2.new(headPos.X - boxWidth/2, headPos.Y - boxHeight/2)
    
    if settings.ESP.RainbowEnabled then
        local hue = (tick() * rainbowSpeed) % 1
        drawings.Box.Color = Color3.fromHSV(hue, 1, 1)
        drawings.Snapline.Color = Color3.fromHSV(hue, 1, 1)
    else
        drawings.Box.Color = settings.ESP.BoxColor
        drawings.Snapline.Color = settings.ESP.BoxColor
    end
    
    drawings.Box.Visible = true
    
    if settings.ESP.DistanceEnabled then
        drawings.Distance.Text = math.floor(distance) .. "m"
        drawings.Distance.Position = Vector2.new(headPos.X, headPos.Y + boxHeight/2 + 15)
        drawings.Distance.Visible = true
    else
        drawings.Distance.Visible = false
    end
    
    if settings.ESP.SnaplineEnabled then
        local targetY
        if settings.ESP.SnaplinePosition == "Bottom" then
            targetY = camera.ViewportSize.Y
        elseif settings.ESP.SnaplinePosition == "Top" then
            targetY = 0
        else
            targetY = camera.ViewportSize.Y / 2
        end
        
        drawings.Snapline.From = Vector2.new(rootPos.X, rootPos.Y)
        drawings.Snapline.To = Vector2.new(camera.ViewportSize.X/2, targetY)
        drawings.Snapline.Visible = true
    else
        drawings.Snapline.Visible = false
    end
end

-- ================== FUNGSI FIND TARGETS DALAM FOV ==================
local function findTargetsInFOV()
    local targets = {}
    local fov = settings.Aimbot.FOV
    local center = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
    local fovRadius = (fov / 2) * (camera.ViewportSize.Y / 100)
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character and plr.Character:FindFirstChild("Head") then
            local head = plr.Character.Head
            local headPos, onScreen = camera:WorldToViewportPoint(head.Position)
            
            if onScreen then
                local screenPos = Vector2.new(headPos.X, headPos.Y)
                local distFromCenter = (screenPos - center).Magnitude
                
                if distFromCenter <= fovRadius then
                    local distance = (camera.CFrame.Position - head.Position).Magnitude
                    if distance <= settings.Aimbot.MaxDistance then
                        local direction = (head.Position - camera.CFrame.Position).Unit
                        local ray = Ray.new(camera.CFrame.Position, direction * 500)
                        local hit, _ = workspace:FindPartOnRay(ray, player.Character)
                        
                        if hit and hit:IsDescendantOf(plr.Character) then
                            table.insert(targets, {
                                player = plr,
                                distance = distance,
                                angle = distFromCenter,
                                head = head
                            })
                        end
                    end
                end
            end
        end
    end
    
    if settings.Aimbot.Priority == "Closest" then
        table.sort(targets, function(a, b) return a.distance < b.distance end)
    else
        table.sort(targets, function(a, b) return a.angle < b.angle end)
    end
    
    return targets
end

-- ================== FUNGSI LOCAL PLAYER ==================
local function updateWalkSpeed(speed)
    if player.Character and player.Character:FindFirstChild("Humanoid") then
        player.Character.Humanoid.WalkSpeed = speed
        settings.Local.WalkSpeed = speed
    end
end

local function toggleInfJump()
    settings.Local.InfJump = not settings.Local.InfJump
    if settings.Local.InfJump then
        game:GetService("UserInputService").JumpRequest:Connect(function()
            if settings.Local.InfJump and player.Character and player.Character:FindFirstChild("Humanoid") then
                player.Character.Humanoid:ChangeState("Jumping")
            end
        end)
    end
end

local function toggleNoclip()
    settings.Local.Noclip = not settings.Local.Noclip
    
    if settings.Local.Noclip then
        RunService.Stepped:Connect(function()
            if settings.Local.Noclip and player.Character then
                for _, part in ipairs(player.Character:GetChildren()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end
        end)
    end
end

